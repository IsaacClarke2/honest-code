{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "python3 ~/.claude/integrity/enforce.py"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "command": "python3 ~/.claude/integrity/track_bash.py"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "command": "python3 ~/.claude/integrity/check.py"
      }
    ]
  }
}
